\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Mincer-Zarnowitz scatter of realised inflation against a naive forecast on 120 months of synthetic data.} Dashed line is the 45 degree line of perfect forecasting. Red line is the fitted Mincer-Zarnowitz regression with 95 per cent pointwise band. The slope estimate falls well short of unity and the intercept deviates from zero, indicating both bias (intercept) and under-reaction (slope).}}{6}{figure.caption.6}\protected@file@percent }
\newlabel{fig:mz}{{5}{6}{\textbf {Mincer-Zarnowitz scatter of realised inflation against a naive forecast on 120 months of synthetic data.} Dashed line is the 45 degree line of perfect forecasting. Red line is the fitted Mincer-Zarnowitz regression with 95 per cent pointwise band. The slope estimate falls well short of unity and the intercept deviates from zero, indicating both bias (intercept) and under-reaction (slope)}{figure.caption.6}{}}
