\@writefile{brf}{\backcite{bils2004some}{{3}{4}{figure.caption.4}}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Weighted component contributions to annualised headline inflation, ten-component synthetic panel, 2015 to 2024.} Stacked area of \code  {ik\_decompose()} output. Component heights sum to the headline inflation rate (black overlay). Pandemic-era peak is dominated by energy and transport contributions; housing contributes slowly throughout.}}{4}{figure.caption.3}\protected@file@percent }
\newlabel{fig:decompose}{{2}{4}{\textbf {Weighted component contributions to annualised headline inflation, ten-component synthetic panel, 2015 to 2024.} Stacked area of \code {ik\_decompose()} output. Component heights sum to the headline inflation rate (black overlay). Pandemic-era peak is dominated by energy and transport contributions; housing contributes slowly throughout}{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Four core inflation measures compared against headline on the same synthetic panel.} All four measures agree in the stationary pre-shock regime and in the post-shock tail. They diverge sharply during the spike: exclusion (dropping food and energy by rule) under-attenuates the shock relative to the distribution-based measures (trimmed mean, weighted median), which drop whichever components happen to be at the tails in each month.}}{4}{figure.caption.4}\protected@file@percent }
\newlabel{fig:core}{{3}{4}{\textbf {Four core inflation measures compared against headline on the same synthetic panel.} All four measures agree in the stationary pre-shock regime and in the post-shock tail. They diverge sharply during the spike: exclusion (dropping food and energy by rule) under-attenuates the shock relative to the distribution-based measures (trimmed mean, weighted median), which drop whichever components happen to be at the tails in each month}{figure.caption.4}{}}
\citation{hodrick1997postwar}
\citation{ravn2002adjusting}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Phillips curve scatter and ordinary-least-squares fit on 40 quarters of synthetic data, 2015 Q1 to 2024 Q4.} Quarterly inflation on the vertical axis, output gap on the horizontal. Points coloured from sky blue (earliest) to deep red (latest). Dashed lines mark zero output gap and the 2 per cent inflation target. Slope estimate 0.58, $R^2 = 0.52$. The pandemic-era cluster in the top-right traces a steeper short-run Phillips relationship.}}{5}{figure.caption.5}\protected@file@percent }
\newlabel{fig:phillips}{{4}{5}{\textbf {Phillips curve scatter and ordinary-least-squares fit on 40 quarters of synthetic data, 2015 Q1 to 2024 Q4.} Quarterly inflation on the vertical axis, output gap on the horizontal. Points coloured from sky blue (earliest) to deep red (latest). Dashed lines mark zero output gap and the 2 per cent inflation target. Slope estimate 0.58, $R^2 = 0.52$. The pandemic-era cluster in the top-right traces a steeper short-run Phillips relationship}{figure.caption.5}{}}
