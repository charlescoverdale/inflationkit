\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces \textbf  {Summary statistics of four core inflation measures and headline on the ten-year synthetic panel.} Values are annualised per cent. Correlation is the Pearson correlation of the core series with headline over the full 120-month panel. All four cores attenuate the pandemic peak relative to headline, with the weighted median attenuating most and the fixed exclusion rule least.}}{7}{table.caption.7}\protected@file@percent }
\newlabel{tab:compare}{{1}{7}{\textbf {Summary statistics of four core inflation measures and headline on the ten-year synthetic panel.} Values are annualised per cent. Correlation is the Pearson correlation of the core series with headline over the full 120-month panel. All four cores attenuate the pandemic peak relative to headline, with the weighted median attenuating most and the fixed exclusion rule least}{table.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {US CPI inflation applied through \href  {https://CRAN.R-project.org/package=inflationkit}{{\normalfont  \fontseries  {b}\selectfont  inflationkit}}, 2015 to 2026.} Monthly year-over-year growth of the headline CPI (\code  {CPIAUCSL}, grey) and less-food-and-energy core (\code  {CPILFESL}, blue), sourced from FRED. HP trend (red dashed) extracted via \code  {ik\_trend(method = "hp", lambda = 14400)}. Shaded window marks April 2021 to December 2023. Dashed horizontal line at 2 per cent is the Federal Reserve's long-run target. Sum-of-autoregressive-coefficients persistence on headline, estimated by \code  {ik\_persistence()} with BIC-selected lag length, is 0.97.}}{7}{figure.caption.8}\protected@file@percent }
\newlabel{fig:fred}{{6}{7}{\textbf {US CPI inflation applied through \CRANpkg {inflationkit}, 2015 to 2026.} Monthly year-over-year growth of the headline CPI (\code {CPIAUCSL}, grey) and less-food-and-energy core (\code {CPILFESL}, blue), sourced from FRED. HP trend (red dashed) extracted via \code {ik\_trend(method = "hp", lambda = 14400)}. Shaded window marks April 2021 to December 2023. Dashed horizontal line at 2 per cent is the Federal Reserve's long-run target. Sum-of-autoregressive-coefficients persistence on headline, estimated by \code {ik\_persistence()} with BIC-selected lag length, is 0.97}{figure.caption.8}{}}
